.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #0a0a0f 0%, #0f0f1a 40%, #12122a 100%);
  display: flex;
  flex-direction: column;
}

/* 顶部栏 */
.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  border-bottom: 1px solid var(--border-subtle);
  flex-shrink: 0;
}

.back-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

.back-btn:active {
  background: rgba(255,255,255,0.05);
}

.back-arrow {
  font-size: 32rpx;
  color: var(--accent-cyan);
}

.back-text {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.history-count {
  font-size: 22rpx;
  color: var(--text-muted);
  letter-spacing: 2rpx;
}

/* 标题区 */
.title-section {
  padding: 40rpx 40rpx 20rpx;
  flex-shrink: 0;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  background: linear-gradient(135deg, #e8e8f0 0%, #a0a0d0 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.subtitle {
  display: block;
  font-size: 24rpx;
  color: var(--text-muted);
  margin-top: 8rpx;
}

/* 空状态 */
.empty-state {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 60rpx;
  padding-bottom: 120rpx;
}

.empty-icon {
  font-size: 80rpx;
  color: var(--accent-cyan);
  margin-bottom: 24rpx;
  opacity: 0.6;
}

.empty-title {
  font-size: 30rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.empty-desc {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-bottom: 48rpx;
}

.empty-btn {
  height: 80rpx;
  padding: 0 48rpx;
  background: linear-gradient(135deg, var(--accent-cyan) 0%, var(--accent-purple) 100%);
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #0a0a0f;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.empty-btn::after {
  border: none;
}

/* 列表 */
.list-scroll {
  flex: 1;
  padding: 20rpx 32rpx 0;
}

.story-card {
  background: var(--bg-card);
  border: 1px solid var(--border-subtle);
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  transition: all 0.2s;
}

.story-card:active {
  border-color: var(--border-neon);
  background: rgba(0, 245, 255, 0.03);
  transform: translateY(-2rpx);
}

.card-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.card-tags {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.card-tag {
  font-size: 20rpx;
  color: var(--accent-cyan);
  border: 1px solid var(--border-neon);
  border-radius: 12rpx;
  padding: 4rpx 16rpx;
  letter-spacing: 1rpx;
}

.card-source {
  font-size: 18rpx;
  border-radius: 10rpx;
  padding: 2rpx 12rpx;
}

.card-source.ai {
  color: var(--accent-green);
  border: 1px solid rgba(34, 211, 187, 0.3);
  background: rgba(34, 211, 187, 0.08);
}

.card-source.mock {
  color: var(--accent-amber);
  border: 1px solid rgba(245, 158, 11, 0.3);
  background: rgba(245, 158, 11, 0.08);
}

.card-time {
  font-size: 22rpx;
  color: var(--text-muted);
}

.card-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
  line-height: 1.4;
}

.card-choice {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 6rpx;
}

.card-branch {
  display: block;
  font-size: 20rpx;
  color: var(--text-muted);
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-top: 1px solid var(--border-subtle);
  padding-top: 16rpx;
}

.card-preview {
  font-size: 22rpx;
  color: var(--text-muted);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
  margin-right: 16rpx;
}

.card-arrow {
  font-size: 28rpx;
  color: var(--text-muted);
  flex-shrink: 0;
}

/* 底部操作 */
.list-actions {
  display: flex;
  justify-content: center;
  padding: 20rpx 0;
}

.clear-btn {
  background: transparent;
  border: 1px solid rgba(236, 72, 153, 0.2);
  color: rgba(236, 72, 153, 0.6);
  font-size: 24rpx;
  padding: 12rpx 32rpx;
  border-radius: 24rpx;
}

.clear-btn::after {
  border: none;
}

.clear-btn:active {
  background: rgba(236, 72, 153, 0.08);
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.75);
  z-index: 100;
  display: flex;
  align-items: flex-end;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s;
}

.modal-mask.show {
  opacity: 1;
  pointer-events: auto;
}

.modal-content {
  width: 100%;
  max-height: 85vh;
  background: var(--bg-card);
  border-radius: 24rpx 24rpx 0 0;
  display: flex;
  flex-direction: column;
  transform: translateY(100%);
  transition: transform 0.35s ease;
}

.modal-mask.show .modal-content {
  transform: translateY(0);
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  border-bottom: 1px solid var(--border-subtle);
  flex-shrink: 0;
}

.modal-tags {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.modal-tag {
  font-size: 22rpx;
  color: var(--accent-cyan);
  border: 1px solid var(--border-neon);
  border-radius: 12rpx;
  padding: 4rpx 16rpx;
}

.modal-source {
  font-size: 20rpx;
  border-radius: 10rpx;
  padding: 3rpx 14rpx;
}

.modal-source.ai {
  color: var(--accent-green);
  border: 1px solid rgba(34, 211, 187, 0.3);
  background: rgba(34, 211, 187, 0.08);
}

.modal-source.mock {
  color: var(--accent-amber);
  border: 1px solid rgba(245, 158, 11, 0.3);
  background: rgba(245, 158, 11, 0.08);
}

.modal-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  font-size: 28rpx;
  color: var(--text-secondary);
}

.modal-close:active {
  background: rgba(255,255,255,0.05);
}

.modal-scroll {
  flex: 1;
  padding: 32rpx;
  max-height: 55vh;
}

.modal-story {
  font-size: 28rpx;
  color: #c8c8dc;
  line-height: 2;
  white-space: pre-wrap;
}

/* 新格式：结构化详情 */
.mod-title {
  display: block;
  font-size: 34rpx; font-weight: 700;
  color: var(--text-primary); margin-bottom: 8rpx;
}
.mod-choice, .mod-branch {
  display: block;
  font-size: 22rpx; color: var(--text-muted); margin-bottom: 4rpx;
}
.mod-label {
  display: block;
  font-size: 22rpx; color: var(--accent-cyan); letter-spacing: 3rpx;
  margin-top: 28rpx; margin-bottom: 12rpx;
  padding-bottom: 8rpx;
  border-bottom: 1px solid var(--border-subtle);
}
.mod-text {
  display: block;
  font-size: 28rpx; color: #c8c8dc; line-height: 1.9;
  white-space: pre-wrap;
}

/* 弹窗内时间线 */
.mod-timeline {
  position: relative; padding-left: 28rpx; margin-left: 8rpx;
  border-left: 2rpx solid rgba(0,245,255,0.15);
}
.mod-tl-item { margin-bottom: 22rpx; }
.mod-tl-year {
  display: block;
  font-size: 20rpx; color: var(--accent-cyan); letter-spacing: 2rpx;
  margin-bottom: 4rpx; font-weight: 600;
}
.mod-tl-event {
  display: block;
  font-size: 26rpx; color: var(--text-primary); line-height: 1.7;
}

.mod-choices { margin-top: 8rpx; }
.mod-choice-item {
  display: block;
  font-size: 24rpx; color: var(--text-secondary);
  padding: 8rpx 0; line-height: 1.5;
}

.modal-footer {
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  border-top: 1px solid var(--border-subtle);
  flex-shrink: 0;
}

.modal-btn {
  width: 100%;
  height: 72rpx;
  background: transparent;
  border: 1px solid rgba(236, 72, 153, 0.2);
  border-radius: 36rpx;
  font-size: 26rpx;
  color: rgba(236, 72, 153, 0.7);
}

.modal-btn::after {
  border: none;
}

.modal-btn:active {
  background: rgba(236, 72, 153, 0.08);
}
