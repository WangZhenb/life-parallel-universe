.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #0a0a0f 0%, #0f0f1a 40%, #12122a 100%);
  overflow: hidden;
  position: relative;
}

/* 星空背景 */
.stars-container {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 0;
}

.star {
  position: absolute;
  width: 3rpx;
  height: 3rpx;
  background: white;
  border-radius: 50%;
  animation: twinkle 3s ease-in-out infinite;
  opacity: 0;
}

@keyframes twinkle {
  0%, 100% { opacity: 0; }
  50%      { opacity: 0.8; }
}

.content {
  position: relative;
  z-index: 1;
  padding: 80rpx 40rpx 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* Hero */
.hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 64rpx;
}

.logo-line {
  width: 60rpx;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, var(--accent-cyan), transparent);
  margin: 24rpx 0;
}

.title-en {
  font-size: 24rpx;
  letter-spacing: 12rpx;
  color: var(--accent-cyan);
  font-weight: 300;
  margin-bottom: 16rpx;
}

.title-cn {
  font-size: 44rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  background: linear-gradient(135deg, #e8e8f0 0%, #a0a0d0 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.subtitle {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-top: 12rpx;
  font-weight: 300;
}

/* 输入区 */
.input-section {
  width: 100%;
  max-width: 640rpx;
  margin-bottom: 40rpx;
}

.label {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
  display: block;
  letter-spacing: 2rpx;
}

.choice-input {
  width: 100%;
  min-height: 120rpx;
  background: var(--bg-card);
  border: 1px solid var(--border-subtle);
  border-radius: 16rpx;
  padding: 24rpx;
  color: var(--text-primary);
  font-size: 30rpx;
  box-sizing: border-box;
  transition: border-color 0.3s;
  line-height: 1.6;
}

.choice-input:focus {
  border-color: var(--border-neon);
  box-shadow: var(--shadow-neon);
}

.char-count {
  text-align: right;
  font-size: 22rpx;
  color: var(--text-muted);
  margin-top: 8rpx;
}

/* 风格选择器 */
.style-section {
  width: 100%;
  max-width: 640rpx;
  margin-bottom: 48rpx;
}

.style-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.style-card {
  flex: 1 1 calc(33.33% - 12rpx);
  min-width: 180rpx;
  background: var(--bg-card);
  border: 1px solid var(--border-subtle);
  border-radius: 14rpx;
  padding: 20rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  transition: all 0.25s ease;
}

.style-card.active {
  border-color: var(--accent-cyan);
  background: rgba(0, 245, 255, 0.06);
  box-shadow: 0 0 16px rgba(0, 245, 255, 0.15);
  transform: translateY(-4rpx);
}

.style-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.style-name {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}

.style-desc {
  font-size: 20rpx;
  color: var(--text-muted);
  line-height: 1.3;
}

/* 生成按钮 */
.action-section {
  width: 100%;
  max-width: 640rpx;
  margin-bottom: 32rpx;
}

.generate-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, var(--accent-cyan) 0%, var(--accent-purple) 100%);
  border: none;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  position: relative;
  overflow: hidden;
}

.generate-btn::after {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 300%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.1), transparent);
  animation: shimmer 2.5s infinite;
}

@keyframes shimmer {
  0%   { left: -100%; }
  100% { left: 100%; }
}

.generate-btn.disabled {
  opacity: 0.35;
  animation: none;
}

.generate-btn.disabled::after {
  display: none;
}

.btn-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #0a0a0f;
  letter-spacing: 4rpx;
  position: relative;
  z-index: 1;
}

.btn-arrow {
  font-size: 32rpx;
  color: #0a0a0f;
  position: relative;
  z-index: 1;
  transition: transform 0.3s;
}

.generate-btn:not(.disabled):hover .btn-arrow {
  transform: translateX(6rpx);
}

/* 历史入口 */
.history-entry {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 20rpx 36rpx;
  border: 1px solid var(--border-subtle);
  border-radius: 32rpx;
  margin-bottom: 20rpx;
  transition: all 0.25s;
}

.history-entry:active {
  border-color: var(--border-neon);
  background: rgba(0, 245, 255, 0.04);
  transform: translateY(-2rpx);
}

.history-icon-wrap {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(0, 245, 255, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 4rpx;
}

.history-icon {
  font-size: 24rpx;
  color: var(--accent-cyan);
}

.history-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  letter-spacing: 2rpx;
}

.history-count {
  font-size: 20rpx;
  color: var(--accent-cyan);
  background: rgba(0, 245, 255, 0.1);
  padding: 2rpx 12rpx;
  border-radius: 16rpx;
  min-width: 28rpx;
  text-align: center;
}

.history-arrow {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-left: 4rpx;
}

/* 底部提示 */
.footer-hint {
  font-size: 22rpx;
  color: var(--text-muted);
  letter-spacing: 2rpx;
}
